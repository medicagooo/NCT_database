# Copy to `.dev.vars` before running local Worker development:
# cp .env.example .dev.vars
#
# The same keys should be set in Cloudflare Variables / Secrets for remote deploys.
# They are intentionally not stored in `wrangler.toml`, so Git-based deploys
# with `wrangler deploy --keep-vars` do not overwrite Dashboard values.
# Cloudflare bindings required by this Worker but not set through `.env`:
# - `DB`: D1 database binding, configured in `wrangler.toml`
# - `ASSETS`: static asset binding generated by Wrangler from `[assets]`
# Optional when R2 is enabled:
# - `EXPORT_BUCKET`: R2 bucket binding for scheduled/admin exports
# - `MEDIA_BUCKET`: R2 bucket binding for mirrored school media objects
#
# Production routing (from wrangler.toml):
#   testdb.medicago.top   -> NCT_database  (this Worker)
#   testbk.medicago.top   -> NCT_backend   (sub)
#   testnct.medicago.top  -> NCT_frontend
# This Worker has no outbound URL env vars to set; the sub registers its own
# `SERVICE_PUBLIC_URL` (e.g. `https://testbk.medicago.top`) via `/api/sub/report`,
# and the mother derives every push / pull / databack URL from that registration.
# Just set the secrets/vars below in Cloudflare Dashboard for the production deploy.
#
# Tables below are sorted by importance.
# `Default` means the runtime behavior when the variable is omitted.

# Priority 1 - Required for any safe deployment
# | Env Var | Default | Purpose |
# | --- | --- | --- |
# | `ENCRYPTION_KEY` | none | Required symmetric key for encrypting and decrypting protected record fields. |
ENCRYPTION_KEY=replace-with-openssl-rand-base64-32

# Priority 2 - Optional export email delivery
# | Env Var | Default | Purpose |
# | --- | --- | --- |
# | `RESEND_API_KEY` | blank | Enables export email sending through Resend. |
# | `EXPORT_EMAIL_TO` | blank | Destination address for export email delivery. |
# | `EXPORT_EMAIL_FROM` | blank | Sender address used by Resend export emails. |
RESEND_API_KEY=
EXPORT_EMAIL_TO=
EXPORT_EMAIL_FROM=

# Priority 3 - Optional media R2 capacity alerts
# | Env Var | Default | Purpose |
# | --- | --- | --- |
# | `MEDIA_CAPACITY_ALERT_BYTES` | `8000000000` | Send an email when the media R2 bucket reaches this size; default is 8 GB. |
# | `MEDIA_CAPACITY_ALERT_MIN_INTERVAL_MS` | `86400000` | Minimum interval between repeated capacity emails while still above threshold. |
# | `MEDIA_CAPACITY_ALERT_EMAIL_TO` | `EXPORT_EMAIL_TO` | Optional override for media capacity alert recipient. |
# | `MEDIA_CAPACITY_ALERT_EMAIL_FROM` | `EXPORT_EMAIL_FROM` | Optional override for media capacity alert sender. |
MEDIA_CAPACITY_ALERT_BYTES=8000000000
MEDIA_CAPACITY_ALERT_MIN_INTERVAL_MS=86400000
MEDIA_CAPACITY_ALERT_EMAIL_TO=
MEDIA_CAPACITY_ALERT_EMAIL_FROM=

# Priority 4 - Optional naming and tuning
# | Env Var | Default | Purpose |
# | --- | --- | --- |
# | `APP_NAME` | `NCT API SQL` | Human-readable service name used in health and export responses. |
# | `DEFAULT_ENCRYPT_FIELDS` | `name,phone,email,idCard` | Comma-separated fallback list of raw payload fields to encrypt when a record does not specify `encryptFields`. |
# | `SUB_AUTH_MAX_FAILURES` | `5` | Number of sub auth failures before the mother blacklists that token-bound sub identity. |
# | `SUB_REPORT_MIN_INTERVAL_MS` | `5000` | Minimum time between accepted sub reports from the same verified sub service. |
# | `SUB_PULL_BATCH_SIZE` | `10` | Maximum number of registered subs processed in one recovery pull run. |
# | `SUB_PULL_MAX_ATTEMPTS` | `5` | Maximum consecutive attempts for each mother-to-sub databack export request. |
# | `SUB_PULL_RECORD_LIMIT` | `100` | Maximum number of databack rows requested from a sub in each pull page. |
# | `SUB_PULL_RETRY_DELAY_MS` | `60000` | Delay between failed mother-to-sub databack export attempts. |
# | `SUB_PULL_TIMEOUT_MS` | `10000` | Timeout for each mother-to-sub recovery pull request. |
APP_NAME="NCT API SQL"
DEFAULT_ENCRYPT_FIELDS=name,phone,email,idCard
SUB_AUTH_MAX_FAILURES=5
SUB_REPORT_MIN_INTERVAL_MS=5000
SUB_PULL_BATCH_SIZE=10
SUB_PULL_MAX_ATTEMPTS=5
SUB_PULL_RECORD_LIMIT=100
SUB_PULL_RETRY_DELAY_MS=60000
SUB_PULL_TIMEOUT_MS=10000
