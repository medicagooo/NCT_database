# Copy to `.dev.vars` before running local Worker development:
# cp .env.example .dev.vars
#
# The same keys can be set in Cloudflare Variables / Secrets for remote deploys.
# Cloudflare bindings required by this Worker but not set through `.env`:
# - `DB`: D1 database binding, configured in `wrangler.toml`
# - `ASSETS`: static asset binding generated by Wrangler from `[assets]`
# - `EXPORT_BUCKET`: R2 bucket binding, configured in `wrangler.toml`
#
# Tables below are sorted by importance.
# `Default` means the runtime behavior when the variable is omitted.

# Priority 1 - Required for any safe deployment
# | Env Var | Default | Purpose |
# | --- | --- | --- |
# | `ENCRYPTION_KEY` | none | Required symmetric key for encrypting and decrypting protected record fields. |
# | `INGEST_TOKEN` | blank | Protects `POST /api/ingest`; if blank, ingest falls back to Console admin auth. |
ENCRYPTION_KEY=replace-with-openssl-rand-base64-32
INGEST_TOKEN=

# Priority 2 - Required for mother/sub secure linkage
# | Env Var | Default | Purpose |
# | --- | --- | --- |
# | `SERVICE_SIGNING_PRIVATE_KEY` | none | Mother signing key used to sign push, pull, and accepted payload responses for subs. |
# | `SERVICE_ENCRYPTION_PRIVATE_KEY` | none | Mother RSA private key used to decrypt recovery payloads and derive the public key shared with subs. |
SERVICE_SIGNING_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-signing-private-key\n-----END PRIVATE KEY-----"
SERVICE_ENCRYPTION_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nreplace-with-encryption-private-key\n-----END PRIVATE KEY-----"

# Priority 3 - Optional export email delivery
# | Env Var | Default | Purpose |
# | --- | --- | --- |
# | `RESEND_API_KEY` | blank | Enables export email sending through Resend. |
# | `EXPORT_EMAIL_TO` | blank | Destination address for export email delivery. |
# | `EXPORT_EMAIL_FROM` | blank | Sender address used by Resend export emails. |
RESEND_API_KEY=
EXPORT_EMAIL_TO=
EXPORT_EMAIL_FROM=

# Priority 4 - Optional naming and tuning
# | Env Var | Default | Purpose |
# | --- | --- | --- |
# | `APP_NAME` | `NCT API SQL` | Human-readable service name used in health, export, and signed responses. |
# | `DEFAULT_ENCRYPT_FIELDS` | `name,phone,email,idCard` | Comma-separated fallback list of raw payload fields to encrypt when a record does not specify `encryptFields`. |
# | `SUB_AUTH_MAX_FAILURES` | `5` | Number of sub auth failures before the mother blacklists that token-bound sub identity. |
# | `SUB_REPORT_MIN_INTERVAL_MS` | `5000` | Minimum time between accepted sub reports from the same verified sub service. |
# | `SUB_PULL_BATCH_SIZE` | `10` | Maximum number of registered subs processed in one recovery pull run. |
# | `SUB_PULL_RECORD_LIMIT` | `100` | Maximum number of databack rows requested from a sub in each pull page. |
# | `SUB_PULL_TIMEOUT_MS` | `10000` | Timeout for each mother-to-sub recovery pull request. |
APP_NAME="NCT API SQL"
DEFAULT_ENCRYPT_FIELDS=name,phone,email,idCard
SUB_AUTH_MAX_FAILURES=5
SUB_REPORT_MIN_INTERVAL_MS=5000
SUB_PULL_BATCH_SIZE=10
SUB_PULL_RECORD_LIMIT=100
SUB_PULL_TIMEOUT_MS=10000
